import os
import csv

class WeatherReport:
    def __init__(self, path):
        self.path = path
        self.max_temps = []
        self.min_temps = []
        self.humid = []
        self.maxtemp = None
        self.mintemp = None
        self.maxhumid = None
        self.date_maxtemp = ""
        self.date_mintemp = ""
        self.date_maxhumid = ""
        self.RED = "\033[91m"
        self.BLUE = "\033[94m"
        self.END = "\033[0m" 

    def max_temperature(self, row):
        max_temp_row = int(row['Max TemperatureC'])
        if self.maxtemp is None or max_temp_row > self.maxtemp:
            self.maxtemp = max_temp_row
            self.date_maxtemp = row['PKT']
        return self.maxtemp, self.date_maxtemp 
    def min_temperature(self, row):
        min_temp_row = int(row['Min TemperatureC'])
        if self.mintemp is None or min_temp_row < self.mintemp:
            self.mintemp = min_temp_row
            self.date_mintemp = row['PKT']
        return self.mintemp, self.date_mintemp
    def max_humidity(self, row):
        max_humid_row = int(row['Max Humidity'])
        if self.maxhumid is None or max_humid_row > self.maxhumid:
            self.maxhumid = max_humid_row
            self.date_maxhumid = row['PKT']
        return self.maxhumid, self.date_maxhumid       


    def yearly_report(self, year):
        for file in os.listdir(self.path):
            if year in file:
                file_path = os.path.join(self.path, file)
                with open(file_path, 'r', encoding='utf-8-sig', errors='ignore') as f:
                    lines = [line for line in f if line.strip() and not line.startswith("<")]
                    header = [h.strip() for h in lines[0].split(",")]
                    csv_reader = csv.DictReader(lines[1:], fieldnames=header)

                    for row in csv_reader:
                        row = { (k.strip() if k else ""): v for k, v in row.items() }
                        if row.get('PKT') == 'PKT' or any(not row.get(field) for field in ['PKT', 'Max TemperatureC', 'Min TemperatureC', 'Max Humidity']):
                            continue
                        max_temp, date_max_temp = self.max_temperature(row)
                        min_temp, date_min_temp = self.min_temperature(row)
                        max_humid, date_max_humid = self.max_humidity(row)                    
                        

        print(f"Max Temperature: {self.maxtemp} on {self.date_maxtemp}")
        print(f"Min Temperature: {self.mintemp} on {self.date_mintemp}")
        print(f"Max Humidity: {self.maxhumid} on {self.date_maxhumid}")

    def average_report(self, year, month):
        
        for file in os.listdir(self.path):
            if year in file and month in file:
                file_path = os.path.join(self.path, file)
                with open(file_path, 'r', encoding='utf-8-sig', errors='ignore') as f:
                    lines = [line for line in f if line.strip() and not line.startswith("<")]
                    header = [h.strip() for h in lines[0].split(",")]
                    csv_reader = csv.DictReader(lines[1:], fieldnames=header)

                    for row in csv_reader:
                        row = { (k.strip() if k else ""): v for k, v in row.items() }

                        if row.get('PKT') == 'PKT' or any(not row.get(field) for field in ['PKT', 'Max TemperatureC', 'Min TemperatureC', 'Max Humidity']):
                            continue

                        self.max_temps.append(int(row['Max TemperatureC']))
                        self.min_temps.append(int(row['Min TemperatureC']))
                        self.humid.append(int(row['Max Humidity']))

        avg_max = sum(self.max_temps) // len(self.max_temps) if self.max_temps else 0
        avg_min = sum(self.min_temps) // len(self.min_temps) if self.min_temps else 0
        avg_humid = sum(self.humid) // len(self.humid) if self.humid else 0

        print(f'Highest Average: {avg_max}')
        print(f'Lowest Average: {avg_min}')
        print(f'Average Humidity: {avg_humid}')

    def monthly_report(self, year, month):
        for file in os.listdir(self.path):
            if year in file and month in file:
                file_path = os.path.join(self.path, file)
                with open(file_path, 'r', encoding='utf-8-sig', errors='ignore') as f:
                    lines = [line for line in f if line.strip() and not line.startswith("<")]
                    header = [h.strip() for h in lines[0].split(",")]
                    csv_reader = csv.DictReader(lines[1:], fieldnames=header)

                    for row in csv_reader:
                        row = { (k.strip() if k else ""): v for k, v in row.items() }

                        if row.get('PKT') == 'PKT' or any(not row.get(field) for field in ['PKT', 'Max TemperatureC', 'Min TemperatureC', 'Max Humidity']):
                            continue

                        day = row['PKT'].split("-")[2]
                        max_temp = int(row['Max TemperatureC'])
                        min_temp = int(row['Min TemperatureC'])

                        print(f"{day} {self.RED}{'+' * 10} {max_temp}C{self.END}")
                        print(f"{day} {self.BLUE}{'+' * 10} {min_temp}C{self.END}")

    def monthly_report_color(self, year, month):
        for file in os.listdir(self.path):
            if year in file and month in file:
                file_path = os.path.join(self.path, file)
                with open(file_path, 'r', encoding='utf-8-sig', errors='ignore') as f:
                    lines = [line for line in f if line.strip() and not line.startswith("<")]
                    header = [h.strip() for h in lines[0].split(",")]
                    csv_reader = csv.DictReader(lines[1:], fieldnames=header)
                    for row in csv_reader:
                        row = { (k.strip() if k else ""): v for k, v in row.items() }
                        if row.get('PKT') == 'PKT' or any(not row.get(field) for field in ['PKT', 'Max TemperatureC', 'Min TemperatureC', 'Max Humidity']):
                            continue
                        day = row['PKT'].split("-")[2]
                        max_temp = int(row['Max TemperatureC'])
                        min_temp = int(row['Min TemperatureC'])
                        print(f"{day} {'+' * 10} {self.RED}{max_temp}C{self.END} - {self.BLUE}{min_temp}C{self.END}")
